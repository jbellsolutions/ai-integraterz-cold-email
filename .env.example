# Cold Email 2.0 — required environment variables.
# Copy to .env and fill in real values. NEVER commit .env.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Smartlead ---
# Get from: smartlead.ai → Settings → API
SMARTLEAD_API_KEY=...

# --- Slack ---
# Bot user token from your Slack app (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...
# Channel for reply-approval pings (where the daemon posts drafted replies)
SLACK_REPLY_CHANNEL=#cold-email-replies
# Channel ID where you talk to the orchestrator agent.
# Use the channel ID (starts with C/G), not the #name — bots without
# channels:read scope can only resolve IDs.
SLACK_CONTROL_CHANNEL=C0XXXXXXXX

# --- Optional ---
# CE2_MOCK_SMARTLEAD=1     # use mock Smartlead CLI for testing
# CE2_MOCK_SLACK=1          # print Slack messages instead of posting
# CE2_SLACK_AGENT_MODEL=claude-sonnet-4-5-20250929
